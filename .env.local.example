# Supabase — get these from your project's API settings (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, used by the admin panel. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
